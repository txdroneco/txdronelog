# Copy this file to .env.prod and fill in real values.
# .env.prod is gitignored — never commit real secrets to the repo.
#
# Generate strong random passwords with:
#   openssl rand -base64 32

# Master password required to create new profiles inside the app.
PROFILE_CREATION_PASS=replace-with-strong-random-password

# Initial password for the default profile on first startup.
# Has no effect after the first boot — change in-app afterwards.
DEFAULT_PROFILE_PASSWORD=replace-with-strong-random-password

# Optional: your own DJI Developer API key for better rate limits.
# Get one at https://developer.dji.com/user
# DJI_API_KEY=
